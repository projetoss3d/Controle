# ============================================================
# CONTROLE — variáveis de ambiente (raiz)
# Copie para .env e ajuste. Nada deve ser hardcoded no código.
# ============================================================

# ---- Postgres ----
POSTGRES_USER=controle
POSTGRES_PASSWORD=controle
POSTGRES_DB=controle
POSTGRES_PORT=5432

# ---- Backend ----
BACKEND_PORT=4000
DATABASE_URL=postgresql://controle:controle@localhost:5432/controle?schema=public
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# ---- Storage (S3-compatible: AWS, MinIO, R2, etc.) ----
STORAGE_DRIVER=local           # local | s3
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---- AI / Automations (futuro, externo ou self-hosted) ----
AI_PROVIDER=disabled           # disabled | openai | local
AI_BASE_URL=
AI_API_KEY=

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:4000
